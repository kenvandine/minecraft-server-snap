{
  "name": "minecraft-launcher",
  "version": "1.0.0",
  "description": "Isolated Minecraft modpack launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux AppImage",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg",
    "build": "electron-builder --linux AppImage --win nsis"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
